{
  "manifest_version": 3,
  "name": "Anghami Ad Blocker",
  "version": "1.1.0",
  "description": "Blocks ads on play.anghami.com — network requests, DOM elements, audio/video ads",

  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage"
  ],

  "host_permissions": [
    "https://play.anghami.com/*",
    "https://bus.anghami.com/*",
    "https://lrclib.net/*"
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_ads",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://play.anghami.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}
